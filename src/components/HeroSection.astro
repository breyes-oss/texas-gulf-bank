---
// HeroSection.astro — Full-bleed hero with Texas landscape
---

<section class="relative overflow-hidden bg-brand-navy">
  <!-- Background image with overlay -->
  <div class="absolute inset-0">
    <div class="absolute inset-0 bg-gradient-to-r from-brand-navy/85 via-brand-navy/60 to-brand-navy/30 z-10"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-brand-navy/40 via-transparent to-transparent z-10"></div>
    <!-- Warm Texas landscape gradient as placeholder for real image -->
    <div class="w-full h-full bg-gradient-to-br from-amber-800/40 via-stone-700/30 to-emerald-900/50" 
         style="background-image: url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 1440 800%22><defs><linearGradient id=%22a%22 x1=%220%%22 y1=%220%%22 x2=%22100%%22 y2=%22100%%22><stop offset=%220%%22 stop-color=%22%23d97706%22 stop-opacity=%220.3%22/><stop offset=%2250%%22 stop-color=%22%2378716c%22 stop-opacity=%220.15%22/><stop offset=%22100%%22 stop-color=%22%23145630%22 stop-opacity=%220.4%22/></linearGradient></defs><rect width=%221440%22 height=%22800%22 fill=%22url(%23a)%22/></svg>'); background-size: cover; background-position: center;">
    </div>
  </div>

  <div class="relative z-20 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 sm:py-32 lg:py-44">
    <div class="max-w-2xl">
      <!-- Tagline -->
      <div class="inline-flex items-center gap-2 bg-brand-gold/20 backdrop-blur-sm text-brand-gold-light text-xs font-semibold uppercase tracking-widest px-4 py-2 rounded-full mb-6 border border-brand-gold/20">
        <span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>
        Over 100 Years of Texas Banking
      </div>

      <!-- Headline -->
      <h1 class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-bold text-white leading-[1.1] tracking-tight text-balance">
        A Community Bank
        <span class="block text-brand-gold">Rooted In Texas</span>
      </h1>

      <p class="mt-6 text-lg sm:text-xl text-gray-200/90 leading-relaxed max-w-xl text-balance">
        From the Gulf Coast to your neighborhood — we've been helping Texas families and businesses 
        grow for over a century. Local decisions, real relationships.
      </p>

      <!-- CTA Buttons -->
      <div class="mt-10 flex flex-col sm:flex-row gap-4">
        <a href="#" class="inline-flex items-center justify-center gap-2 bg-brand-gold text-white px-8 py-3.5 rounded-xl text-base font-semibold hover:bg-brand-gold-light transition-all shadow-lg shadow-brand-gold/25 hover:shadow-brand-gold/40 active:scale-[0.98]">
          Open an Account
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a href="#" class="inline-flex items-center justify-center gap-2 border-2 border-white/30 text-white px-8 py-3.5 rounded-xl text-base font-medium hover:bg-white/10 hover:border-white/50 transition-all">
          Find a Branch
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        </a>
      </div>

      <!-- Trust indicators -->
      <div class="mt-12 flex flex-wrap items-center gap-6 text-xs text-gray-400">
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-brand-gold" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          Member FDIC
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-brand-gold" fill="currentColor" viewBox="0 0 20 20"><path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"/></svg>
          Equal Housing Lender
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-brand-gold" fill="currentColor" viewBox="0 0 20 20"><path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/><path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/></svg>
          Secure Online Banking
        </span>
      </div>
    </div>
  </div>

  <!-- Bottom curve divider -->
  <div class="relative z-20">
    <svg class="w-full h-8 sm:h-12 lg:h-16 fill-brand-warm" viewBox="0 0 1440 64" preserveAspectRatio="none">
      <path d="M0,32 C360,64 1080,64 1440,32 L1440,64 L0,64 Z"/>
    </svg>
  </div>
</section>
