---
// HeroSection.astro — Collage-style hero with Texas imagery
---

<section class="relative overflow-hidden bg-brand-warm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-8 lg:gap-12 items-center min-h-[80vh] py-16 lg:py-24">
      
      <!-- Left: Collage of images -->
      <div class="relative h-[400px] lg:h-[500px] animate-fade-in">
        <!-- Photo 1: Texas landscape (back, largest, rotated slightly) -->
        <div class="absolute top-4 left-4 w-[85%] h-[70%] rounded-2xl overflow-hidden shadow-xl rotate-[-2deg] z-10 border-[6px] border-white">
          <div class="w-full h-full bg-gradient-to-br from-amber-600/60 via-amber-800/40 to-emerald-900/60"
               style="background-image: url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 600 400%22><rect width=%22600%22 height=%22400%22 fill=%22%23d97706%22 opacity=%220.3%22/><path d=%22M0 300 Q150 200 300 280 T600 200 L600 400 L0 400 Z%22 fill=%22%23145630%22 opacity=%220.4%22/><circle cx=%22200%22 cy=%22120%22 r=%2260%22 fill=%22%23fbbf24%22 opacity=%220.5%22/><circle cx=%22350%22 cy=%22100%22 r=%2240%22 fill=%22%23f59e0b%22 opacity=%220.4%22/><path d=%22M0 350 Q200 300 400 340 T600 320 L600 400 L0 400 Z%22 fill=%22%230a1628%22 opacity=%220.3%22/></svg>'); background-size: cover; background-position: center;">
          </div>
        </div>

        <!-- Photo 2: Gulf Coast (middle, overlapping) -->
        <div class="absolute bottom-8 right-4 w-[70%] h-[55%] rounded-2xl overflow-hidden shadow-xl rotate-[3deg] z-20 border-[6px] border-white">
          <div class="w-full h-full bg-gradient-to-br from-sky-600/50 via-teal-600/40 to-emerald-800/50"
               style="background-image: url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 500 350%22><rect width=%22500%22 height=%22350%22 fill=%22%230ea5e9%22 opacity=%220.25%22/><path d=%22M0 280 Q100 220 250 260 T500 200 L500 350 L0 350 Z%22 fill=%22%230a1628%22 opacity=%220.35%22/><path d=%22M0 300 Q150 270 300 290 T500 270 L500 350 L0 350 Z%22 fill=%22%23d97706%22 opacity=%220.2%22/><circle cx=%22400%22 cy=%2280%22 r=%2250%22 fill=%22%23fbbf24%22 opacity=%220.4%22/></svg>'); background-size: cover; background-position: center;">
          </div>
        </div>

        <!-- Photo 3: Small town main street (front, smallest, accent) -->
        <div class="absolute top-20 right-8 w-[45%] h-[35%] rounded-2xl overflow-hidden shadow-lg rotate-[-5deg] z-30 border-[6px] border-white">
          <div class="w-full h-full bg-gradient-to-br from-stone-500/40 via-amber-700/30 to-red-900/40"
               style="background-image: url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 400 280%22><rect width=%22400%22 height=%22280%22 fill=%22%2378716c%22 opacity=%220.2%22/><rect x=%2260%22 y=%2240%22 width=%2230%22 height=%22180%22 fill=%22%23d97706%22 opacity=%220.4%22/><rect x=%22120%22 y=%2230%22 width=%2230%22 height=%22190%22 fill=%22%2392460a%22 opacity=%220.35%22/><rect x=%22180%22 y=%2250%22 width=%2230%22 height=%22170%22 fill=%22%23b45309%22 opacity=%220.3%22/><rect x=%22240%22 y=%2235%22 width=%2230%22 height=%22185%22 fill=%22%23d97706%22 opacity=%220.25%22/><rect x=%22300%22 y=%2245%22 width=%2230%22 height=%22175%22 fill=%22%2392460a%22 opacity=%220.3%22/><rect x=%220%22 y=%22220%22 width=%22400%22 height=%2260%22 fill=%22%235b534e%22 opacity=%220.3%22/><circle cx=%2250%22 cy=%2250%22 r=%2220%22 fill=%22%23fbbf24%22 opacity=%220.5%22/></svg>'); background-size: cover; background-position: center;">
          </div>
        </div>

        <!-- Decorative accent dot pattern -->
        <div class="absolute -bottom-4 -left-4 w-32 h-32 bg-brand-gold/10 rounded-full blur-2xl z-0"></div>
        <div class="absolute top-1/2 -right-4 w-24 h-24 bg-brand-navy-light/10 rounded-full blur-xl z-0"></div>
      </div>

      <!-- Right: Content -->
      <div class="relative z-10 animate-fade-in-right">
        <!-- Tagline pill -->
        <div class="inline-flex items-center gap-2 bg-brand-gold/10 text-brand-gold-dark text-xs font-semibold uppercase tracking-widest px-4 py-2 rounded-full mb-6 border border-brand-gold/20">
          <span class="w-1.5 h-1.5 bg-brand-gold-dark rounded-full"></span>
          Over 100 Years of Texas Banking
        </div>

        <!-- Serif headline -->
        <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-bold text-brand-text leading-[1.1] tracking-tight text-balance">
          A Community Bank
          <span class="block text-brand-gold">Rooted In Texas</span>
        </h1>

        <p class="mt-6 text-lg sm:text-xl text-brand-muted leading-relaxed max-w-xl text-balance">
          From the Gulf Coast to your neighborhood — we've been helping Texas families and businesses grow for over a century. Local decisions, real relationships.
        </p>

        <!-- CTA Buttons -->
        <div class="mt-10 flex flex-col sm:flex-row gap-4">
          <a href="#" class="inline-flex items-center justify-center gap-2 bg-brand-gold text-white px-8 py-3.5 rounded-xl text-base font-semibold hover:bg-brand-gold-light transition-all shadow-lg shadow-brand-gold/25 hover:shadow-brand-gold/40 active:scale-[0.98]">
            Open an Account
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
          <a href="#" class="inline-flex items-center justify-center gap-2 border-2 border-brand-gold/30 text-brand-gold-dark px-8 py-3.5 rounded-xl text-base font-medium hover:bg-brand-gold/5 hover:border-brand-gold/50 transition-all">
            Find a Branch
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </a>
        </div>

        <!-- Trust indicators -->
        <div class="mt-12 flex flex-wrap items-center gap-6 text-xs text-brand-muted">
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-brand-gold-dark" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            Member FDIC
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-brand-gold-dark" fill="currentColor" viewBox="0 0 20 20"><path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"/></svg>
            Equal Housing Lender
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-brand-gold-dark" fill="currentColor" viewBox="0 0 20 20"><path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/><path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/></svg>
            Secure Online Banking
          </span>
        </div>
      </div>
    </div>
  </div>
</section>
