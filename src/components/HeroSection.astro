---
// HeroSection.astro — Authentic Gulf Coast community hero
const { home } = Astro.props;
const openAccountUrl = "https://app.loanspq.com/apply.aspx?enc=Kw21Wblm1yxpjJabdoZaD_1XCeB6DUzWcPY_g38Z9Jqr0clsjQUYVmTraoEngafVkCgQedLZhb-S5_xgQhN9fA";
---

<section class="relative overflow-hidden bg-brand-cream">
  <div class="max-w-[1536px] mx-auto px-4 sm:px-6 lg:px-8 py-5 lg:py-7">
    <div class="relative min-h-[650px] lg:min-h-[720px] rounded-[1.5rem] lg:rounded-[2rem] overflow-hidden bg-brand-navy shadow-[0_24px_70px_rgba(10,22,40,0.18)]">
      <img
        src="/hero-community.png"
        alt="Local business owners outside their Gulf Coast storefront"
        class="absolute inset-0 h-full w-full object-cover object-[42%_center]"
        width="1536"
        height="864"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-brand-navy/95 via-brand-navy/78 to-brand-navy/10"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-brand-navy/35 via-transparent to-transparent"></div>

      <div class="relative z-10 max-w-7xl mx-auto min-h-[650px] lg:min-h-[720px] px-6 sm:px-10 lg:px-16 py-16 lg:py-24 flex items-center">
        <div class="max-w-2xl animate-fade-in">
          <div class="inline-flex items-center gap-3 text-brand-gold-light text-xs font-semibold uppercase tracking-[0.2em] mb-7">
            <span class="w-10 h-px bg-brand-gold"></span>
            {home.hero_tagline || "Over 100 Years of Texas Banking"}
          </div>

          <h1 class="font-display text-5xl sm:text-6xl lg:text-7xl xl:text-[5.25rem] font-semibold text-white leading-[0.98] tracking-[-0.035em] text-balance">
            {home.hero_headline || "A Community Bank"}
            <span class="block mt-2 text-brand-gold-light">{home.hero_headline_accent || "Rooted In Texas"}</span>
          </h1>

          <p class="mt-7 text-lg sm:text-xl text-white/82 leading-relaxed max-w-xl text-balance">
            {home.hero_subtext || "From the Gulf Coast to your neighborhood — local decisions and real relationships have helped Texas families and businesses grow for generations."}
          </p>

          <div class="mt-10 flex flex-col sm:flex-row gap-3">
            <a href={openAccountUrl} class="inline-flex items-center justify-center gap-2 bg-brand-gold text-brand-navy px-7 py-3.5 rounded-lg text-base font-bold hover:bg-brand-gold-light transition-all shadow-lg shadow-black/10 active:scale-[0.98]">
              {home.hero_primary_cta || "Open an Account"}
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
            <a href="https://www.texasgulfbank.com/locations/" class="inline-flex items-center justify-center gap-2 bg-white/10 border border-white/35 text-white px-7 py-3.5 rounded-lg text-base font-semibold hover:bg-white hover:text-brand-navy transition-all backdrop-blur-sm">
              {home.hero_secondary_cta || "Find a Branch"}
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </a>
          </div>

          <p class="mt-6 text-xs text-white/65">Personal relationships. Local decision-makers. Texas Gulf Coast expertise.</p>
        </div>
      </div>

      <div class="absolute bottom-5 right-5 hidden md:flex items-center gap-3 rounded-full border border-white/20 bg-brand-navy/55 px-4 py-2 text-xs font-medium text-white/85 backdrop-blur-md">
        <span class="w-2 h-2 rounded-full bg-brand-gold"></span>
        Harris · Galveston · Brazoria
      </div>
    </div>
  </div>
</section>
