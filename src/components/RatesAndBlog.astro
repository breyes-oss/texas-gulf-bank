---
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog");
allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const latestPosts = allPosts.slice(0, 3);

const rates = [
  { name: "12-Month CD", detail: "$2,500 minimum", value: "3.45%" },
  { name: "18-Month CD", detail: "$2,500 minimum", value: "3.30%" },
  { name: "Gulf Advantage Checking", detail: "Requirements apply", value: "0.80%" },
  { name: "Money Market", detail: "$1M+ tier", value: "1.66%" }
];
---

<section class="bg-brand-cream py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-5 gap-12 lg:gap-16">
      <div class="lg:col-span-3 animate-fade-in-left">
        <div class="inline-flex items-center gap-2 text-brand-gold-dark text-xs font-semibold uppercase tracking-widest mb-4">
          <span class="w-8 h-px bg-brand-gold-dark"></span>
          Current Rates
        </div>
        <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-semibold text-brand-text leading-[1.08] tracking-tight text-balance">
          Make more of what<br /><span class="text-brand-navy-light">you've built.</span>
        </h2>
        <p class="mt-4 text-brand-muted text-base">Featured annual percentage yields published July 13, 2026.</p>

        <div class="mt-8 border-y border-brand-navy/15">
          {rates.map((rate) => (
            <div class="grid grid-cols-[1fr_auto] gap-5 items-center py-5 border-b last:border-b-0 border-brand-navy/10">
              <div>
                <p class="font-semibold text-brand-text">{rate.name}</p>
                <p class="text-sm text-brand-muted mt-0.5">{rate.detail}</p>
              </div>
              <div class="text-right">
                <p class="font-display text-3xl font-semibold text-brand-navy-light">{rate.value}</p>
                <p class="text-[11px] font-semibold tracking-[0.16em] text-brand-muted">APY</p>
              </div>
            </div>
          ))}
        </div>

        <p class="mt-5 text-xs text-brand-muted leading-relaxed">Rates may change. Fees may reduce earnings. CD early-withdrawal penalties may apply. See the complete rate sheet for terms and account requirements.</p>
        <a href="https://www.texasgulfbank.com/investment-rate-index-time-and-non-time-accounts/" class="inline-flex items-center gap-2 mt-6 text-brand-navy-light font-semibold hover:text-brand-gold-dark transition-colors text-sm">
          View complete rates and disclosures
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>

      <div class="lg:col-span-2 animate-fade-in-right">
        <div class="inline-flex items-center gap-2 text-brand-gold-dark text-xs font-semibold uppercase tracking-widest mb-4">
          <span class="w-8 h-px bg-brand-gold-dark"></span>
          From the Bank
        </div>
        <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-semibold text-brand-text leading-[1.08] tracking-tight">Local insight.</h2>

        <div class="mt-8 border-t border-brand-navy/15">
          {latestPosts.map((post) => (
            <a href={`/blog/${post.id}`} class="block group py-6 border-b border-brand-navy/10">
              <div class="flex items-center gap-2 text-xs text-brand-muted mb-3">
                <span class="font-semibold uppercase tracking-[0.12em] text-brand-gold-dark">{post.data.category}</span>
                <span aria-hidden="true">·</span>
                <span>{post.data.date}</span>
              </div>
              <h3 class="font-display text-xl font-semibold leading-snug text-brand-text group-hover:text-brand-navy-light transition-colors">{post.data.title}</h3>
              <span class="inline-flex items-center gap-1 mt-3 text-brand-navy-light text-sm font-semibold group-hover:text-brand-gold-dark transition-colors">
                Read article
                <svg class="w-3.5 h-3.5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </span>
            </a>
          ))}
        </div>

        <a href="/blog" class="inline-flex items-center gap-2 mt-6 text-brand-navy-light font-semibold hover:text-brand-gold-dark transition-colors text-sm">
          View all insights
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>
