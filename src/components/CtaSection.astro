---
// CtaSection.astro — Final call to action before footer
const { home } = Astro.props;
---

<section class="bg-brand-navy relative overflow-hidden">
  <!-- Background pattern -->
  <div class="absolute inset-0 opacity-[0.03]">
    <svg class="w-full h-full" viewBox="0 0 1440 400">
      <defs>
        <pattern id="cta-grid" width="60" height="60" patternUnits="userSpaceOnUse">
          <path d="M 60 0 L 0 0 0 60" fill="none" stroke="white" stroke-width="1"/>
        </pattern>
      </defs>
      <rect width="1440" height="400" fill="url(#cta-grid)"/>
    </svg>
  </div>

  <!-- Glow accents -->
  <div class="absolute -top-40 -left-40 w-80 h-80 bg-brand-gold/5 rounded-full blur-3xl"></div>
  <div class="absolute -bottom-40 -right-40 w-80 h-80 bg-brand-gold/5 rounded-full blur-3xl"></div>

  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28 text-center animate-fade-in">
    <div class="inline-flex items-center gap-2 bg-white/5 text-brand-gold-light text-xs font-semibold uppercase tracking-widest px-4 py-2 rounded-full mb-6 border border-white/10 backdrop-blur-sm">
      <span class="w-1.5 h-1.5 bg-brand-gold rounded-full"></span>
      Let's Talk
    </div>

    <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-semibold text-white leading-[1.1] tracking-tight">
      {home.cta_headline || "Ready to bank with"}<br />
      <span class="text-brand-gold">{home.cta_headline_accent || "Texas Gulf Bank?"}</span>
    </h2>

    <p class="mt-5 text-lg text-gray-300 max-w-2xl mx-auto text-balance">
      {home.cta_subtext || "Whether you're opening your first account or growing a business, we're here to help. Stop by any branch or give us a call."}
    </p>

    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="https://www.texasgulfbank.com/locations/" class="inline-flex items-center gap-2 bg-brand-gold text-brand-navy px-8 py-3.5 rounded-xl text-base font-bold hover:bg-brand-gold-light transition-all shadow-lg shadow-brand-gold/20 active:scale-[0.98]">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        {home.cta_primary_button || "Find a Branch Near You"}
      </a>
      <a href="tel:8004677216" class="inline-flex items-center gap-2 border-2 border-white/20 text-white px-8 py-3.5 rounded-xl text-base font-medium hover:bg-white/5 hover:border-white/40 transition-all">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        {home.cta_phone || "800.467.7216"}
      </a>
    </div>
  </div>
</section>
