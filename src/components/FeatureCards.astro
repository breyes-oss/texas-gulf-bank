---
// FeatureCards.astro — Quick action cards
---

<section class="bg-brand-warm pt-8 lg:pt-12 relative z-30 pb-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6">
      <!-- Card 1: Open Account -->
      <a href="#" class="group bg-white rounded-2xl p-6 lg:p-8 shadow-sm hover:shadow-lg border border-gray-100 hover:border-brand-gold/30 transition-all duration-300">
        <div class="w-12 h-12 bg-brand-gold-pale rounded-xl flex items-center justify-center mb-5 group-hover:bg-brand-gold/15 transition-colors">
          <svg class="w-6 h-6 text-brand-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <h2 class="text-lg font-bold text-brand-text mb-2">Open an Account</h2>
        <p class="text-brand-muted text-sm leading-relaxed">Personal checking or savings accounts — ready in just a few steps.</p>
        <span class="inline-flex items-center gap-1 mt-4 text-brand-navy-light text-sm font-semibold group-hover:text-brand-gold transition-colors">
          Get Started
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </span>
      </a>

      <!-- Card 2: Visit a Branch -->
      <a href="#" class="group bg-white rounded-2xl p-6 lg:p-8 shadow-sm hover:shadow-lg border border-gray-100 hover:border-brand-gold/30 transition-all duration-300">
        <div class="w-12 h-12 bg-brand-gold-pale rounded-xl flex items-center justify-center mb-5 group-hover:bg-brand-gold/15 transition-colors">
          <svg class="w-6 h-6 text-brand-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
        </div>
        <h2 class="text-lg font-bold text-brand-text mb-2">Visit a Branch</h2>
        <p class="text-brand-muted text-sm leading-relaxed">12 locations across Harris, Galveston & Brazoria counties.</p>
        <span class="inline-flex items-center gap-1 mt-4 text-brand-navy-light text-sm font-semibold group-hover:text-brand-gold transition-colors">
          Find a Branch
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </span>
      </a>

      <!-- Card 3: Digital Banking -->
      <a href="#" class="group bg-white rounded-2xl p-6 lg:p-8 shadow-sm hover:shadow-lg border border-gray-100 hover:border-brand-gold/30 transition-all duration-300">
        <div class="w-12 h-12 bg-brand-gold-pale rounded-xl flex items-center justify-center mb-5 group-hover:bg-brand-gold/15 transition-colors">
          <svg class="w-6 h-6 text-brand-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
        </div>
        <h2 class="text-lg font-bold text-brand-text mb-2">Digital Banking</h2>
        <p class="text-brand-muted text-sm leading-relaxed">Manage accounts, deposit checks, send money — anytime, anywhere.</p>
        <span class="inline-flex items-center gap-1 mt-4 text-brand-navy-light text-sm font-semibold group-hover:text-brand-gold transition-colors">
          Learn More
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </span>
      </a>

      <!-- Card 4: Business Services -->
      <a href="#" class="group bg-white rounded-2xl p-6 lg:p-8 shadow-sm hover:shadow-lg border border-gray-100 hover:border-brand-gold/30 transition-all duration-300">
        <div class="w-12 h-12 bg-brand-gold-pale rounded-xl flex items-center justify-center mb-5 group-hover:bg-brand-gold/15 transition-colors">
          <svg class="w-6 h-6 text-brand-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        </div>
        <h2 class="text-lg font-bold text-brand-text mb-2">Business Services</h2>
        <p class="text-brand-muted text-sm leading-relaxed">Loans, treasury management, payroll solutions & more.</p>
        <span class="inline-flex items-center gap-1 mt-4 text-brand-navy-light text-sm font-semibold group-hover:text-brand-gold transition-colors">
          Explore
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </span>
      </a>
    </div>
  </div>
</section>
