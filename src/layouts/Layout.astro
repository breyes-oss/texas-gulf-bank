---
export interface Props {
  title: string;
  description: string;
}
import '../styles/global.css';
import FdicDigitalSign from '../components/FdicDigitalSign.astro';

const { title, description } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Texas Gulf Bank N.A.</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Skip Navigation Link (WCAG 2.4.1) -->
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <!-- Top Utility Bar -->
    <div class="bg-brand-navy text-white text-xs">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-9">
        <div class="flex items-center gap-5">
          <a href="#" class="hover:text-brand-gold transition-colors">Locations</a>
          <a href="#" class="hover:text-brand-gold transition-colors">Contact</a>
          <a href="#" class="hover:text-brand-gold transition-colors">Careers</a>
          <a href="#" class="hover:text-brand-gold transition-colors" aria-label="Search">🔍</a>
        </div>
      </div>
    </div>

    <!-- Main Header -->
    <header class="bg-white border-b border-gray-100 sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16 lg:h-20">
          <!-- Logo Area: stacked logo + FDIC sign -->
          <div class="flex flex-col items-start gap-0">
            <a href="/" class="flex items-center group">
              <img src="/logo-navy.svg" alt="Texas Gulf Bank" class="h-8 lg:h-10 w-auto" />
            </a>
            <FdicDigitalSign />
          </div>

          <!-- Desktop Nav -->
          <nav class="hidden lg:flex items-center gap-1">
            <a href="#" class="px-4 py-2 text-sm font-medium text-brand-text hover:text-brand-navy-light rounded-lg hover:bg-gray-50 transition-colors">Business</a>
            <a href="#" class="px-4 py-2 text-sm font-medium text-brand-text hover:text-brand-navy-light rounded-lg hover:bg-gray-50 transition-colors">Personal</a>
            <a href="#" class="px-4 py-2 text-sm font-medium text-brand-text hover:text-brand-navy-light rounded-lg hover:bg-gray-50 transition-colors">Wealth</a>
            <a href="#" class="px-4 py-2 text-sm font-medium text-brand-text hover:text-brand-navy-light rounded-lg hover:bg-gray-50 transition-colors">About</a>
            <a href="#" class="px-4 py-2 text-sm font-medium text-brand-text hover:text-brand-navy-light rounded-lg hover:bg-gray-50 transition-colors">Support</a>
          </nav>

          <!-- CTA + Mobile Toggle -->
          <div class="flex items-center gap-3">
            <a href="#" class="hidden sm:inline-flex items-center gap-2 bg-brand-gold text-white px-5 py-2.5 rounded-lg text-sm font-semibold hover:bg-brand-gold-light transition-colors shadow-sm">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
              Online Banking
            </a>
            <button class="lg:hidden p-2 rounded-lg hover:bg-gray-100 transition-colors" aria-label="Menu">
              <svg class="w-6 h-6 text-brand-text" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
              </svg>
            </button>
          </div>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main id="main-content" class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-brand-navy text-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">
          <!-- Column 1: Business -->
          <div>
            <h3 class="text-brand-gold-dark font-semibold text-sm uppercase tracking-wider mb-4">Business</h3>
            <ul class="space-y-2.5">
              <li><a href="#" class="text-gray-300 hover:text-white text-sm transition-colors">Business Checking</a></li>
              <li><a href="#" class="text-gray-300 hover:text-white text-sm transition-colors">Business Loans</a></li>
              <li><a href="#" class="text-gray-300 hover:text-white text-sm transition-colors">Card Services</a></li>
              <li><a href="#" class="text-gray-300 hover:text-white text-sm transition-colors">Treasury Services</a></li>
              <li><a href="#" class="text-gray-300 hover:text-white text-sm transition-colors">Remote Deposit</a></li>
            </ul>
          </div>
          <!-- Column 2: Personal -->
          <div>
            <h3 class="text-brand-gold-dark font-semibold text-sm uppercase tracking-wider mb-4">Personal</h3>
            <ul class="space-y-2.5">
              <li><a href="#" class="text-gray-300 hover:text-white text-sm transition-colors">Personal Checking</a></li>
              <li><a href="#" class="text-gray-300 hover:text-white text-sm transition-colors">Savings & CDs</a></li>
              <li><a href="#" class="text-gray-300 hover:text-white text-sm transition-colors">Personal Loans</a></li>
              <li><a href="#" class="text-gray-300 hover:text-white text-sm transition-colors">Online Banking</a></li>
              <li><a href="#" class="text-gray-300 hover:text-white text-sm transition-colors">Zelle®</a></li>
            </ul>
          </div>
          <!-- Column 3: Wealth & About -->
          <div>
            <h3 class="text-brand-gold-dark font-semibold text-sm uppercase tracking-wider mb-4">Wealth</h3>
            <ul class="space-y-2.5 mb-8">
              <li><a href="#" class="text-gray-300 hover:text-white text-sm transition-colors">Wealth Management</a></li>
              <li><a href="#" class="text-gray-300 hover:text-white text-sm transition-colors">Special Needs Trusts</a></li>
              <li><a href="#" class="text-gray-300 hover:text-white text-sm transition-colors">Financial Planning</a></li>
            </ul>
            <h3 class="text-brand-gold-dark font-semibold text-sm uppercase tracking-wider mb-4">About</h3>
            <ul class="space-y-2.5">
              <li><a href="#" class="text-gray-300 hover:text-white text-sm transition-colors">Our Story</a></li>
              <li><a href="#" class="text-gray-300 hover:text-white text-sm transition-colors">Leadership</a></li>
              <li><a href="#" class="text-gray-300 hover:text-white text-sm transition-colors">Community</a></li>
              <li><a href="#" class="text-gray-300 hover:text-white text-sm transition-colors">Blog</a></li>
            </ul>
          </div>
          <!-- Column 4: Support + Social -->
          <div>
            <h3 class="text-brand-gold-dark font-semibold text-sm uppercase tracking-wider mb-4">Support</h3>
            <ul class="space-y-2.5 mb-8">
              <li><a href="#" class="text-gray-300 hover:text-white text-sm transition-colors">FAQ</a></li>
              <li><a href="#" class="text-gray-300 hover:text-white text-sm transition-colors">Locations</a></li>
              <li><a href="#" class="text-gray-300 hover:text-white text-sm transition-colors">View Rates</a></li>
              <li><a href="#" class="text-gray-300 hover:text-white text-sm transition-colors">Privacy & Security</a></li>
              <li><a href="#" class="text-gray-300 hover:text-white text-sm transition-colors">Accessibility</a></li>
            </ul>
            <div class="flex items-center gap-3">
              <a href="#" class="w-9 h-9 bg-white/10 rounded-lg flex items-center justify-center hover:bg-brand-gold transition-colors" aria-label="LinkedIn">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
              </a>
              <a href="#" class="w-9 h-9 bg-white/10 rounded-lg flex items-center justify-center hover:bg-brand-gold transition-colors" aria-label="Facebook">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385h-3.047v-3.469h3.047v-2.642c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953h-1.514c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.469h-2.796v8.385c5.737-.9 10.125-5.864 10.125-11.854z"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Bottom Bar -->
      <div class="border-t border-white/10">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex flex-col sm:flex-row items-center justify-between gap-3">
          <div class="flex items-center gap-3 text-xs text-gray-400">
            <span>© 2025 Texas Gulf Bank N.A.</span>
            <span class="hidden sm:inline">·</span>
            <a href="#" class="hover:text-white transition-colors">Privacy Policy</a>
            <span class="hidden sm:inline">·</span>
            <a href="#" class="hover:text-white transition-colors">Terms of Use</a>
            <span class="hidden sm:inline">·</span>
            <a href="#" class="hover:text-white transition-colors">Accessibility</a>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-xs text-gray-400">Equal Housing Lender</span>
            <svg class="w-5 h-5 text-brand-gold" viewBox="0 0 24 24" fill="currentColor"><path d="M12 3L2 12h3v8h6v-6h2v6h6v-8h3L12 3z"/></svg>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
