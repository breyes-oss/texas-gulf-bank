---
export interface Props {
  title: string;
  date: string;
  author?: string;
  image?: string;
  category?: string;
}
const { title, date, image, category } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Texas Gulf Bank Blog</title>
    <meta name="description" content={`${title} — Texas Gulf Bank blog`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/src/styles/global.css" />
  </head>
  <body>
    <!-- Top Utility Bar -->
    <div class="bg-brand-navy text-white text-xs">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-9">
        <div class="flex items-center gap-5">
          <a href="https://tgbtest2.pages.dev/" class="hover:text-brand-gold transition-colors">Home</a>
          <a href="https://tgbtest2.pages.dev/#locations" class="hover:text-brand-gold transition-colors">Locations</a>
          <a href="#" class="hover:text-brand-gold transition-colors">Contact</a>
        </div>
      </div>
    </div>

    <!-- Main Header -->
    <header class="bg-white border-b border-gray-100 sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16 lg:h-20">
          <div class="flex flex-col items-start gap-0">
            <a href="https://tgbtest2.pages.dev/" class="flex items-center group">
              <img src="/logo-navy.svg" alt="Texas Gulf Bank" class="h-8 lg:h-10 w-auto" />
            </a>
          </div>
          <nav class="hidden lg:flex items-center gap-1">
            <a href="https://tgbtest2.pages.dev/" class="px-4 py-2 text-sm font-medium text-brand-text hover:text-brand-navy-light rounded-lg hover:bg-gray-50 transition-colors">Home</a>
            <a href="/blog" class="px-4 py-2 text-sm font-medium text-brand-gold rounded-lg bg-brand-gold-pale/30 transition-colors">Blog</a>
          </nav>
        </div>
      </div>
    </header>

    <main>
      <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
        {image && (
          <div class="mb-8 rounded-2xl overflow-hidden bg-brand-cream">
            <img src={image} alt={title} class="w-full h-48 sm:h-64 object-cover" />
          </div>
        )}
        <div class="flex items-center gap-3 text-sm text-brand-muted mb-4">
          {category && <span class="bg-brand-gold-pale text-brand-gold font-semibold px-2.5 py-1 rounded-full text-xs">{category}</span>}
          <time datetime={date}>{date}</time>
        </div>
        <h1 class="text-3xl sm:text-4xl font-bold text-brand-text leading-tight mb-8">{title}</h1>
        <div class="prose prose-lg max-w-none text-brand-text">
          <slot />
        </div>
      </article>
    </main>

    <!-- Footer -->
    <footer class="bg-brand-navy text-white mt-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
          <p class="text-sm text-gray-400">© 2025 Texas Gulf Bank N.A.</p>
          <a href="https://tgbtest2.pages.dev/" class="text-brand-gold hover:text-brand-gold-light text-sm transition-colors">Back to Home</a>
        </div>
      </div>
    </footer>
  </body>
</html>
